# ──────────────────────────────────────
# LedgerAI — Environment Configuration
# ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenAI API Key (from platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL Database URL
# If using docker-compose, use: postgresql+asyncpg://ledgerai:ledgerai@db:5432/ledgerai
# If using local PostgreSQL:   postgresql+asyncpg://user:password@localhost:5432/ledgerai
DATABASE_URL=postgresql+asyncpg://ledgerai:ledgerai@db:5432/ledgerai

# Sync version of the database URL (used for migrations/seeding)
DATABASE_URL_SYNC=postgresql+psycopg2://ledgerai:ledgerai@db:5432/ledgerai

# PostgreSQL password (used by docker-compose)
DB_PASSWORD=ledgerai

# ──────────────────────────────────────
# Optional Configuration
# ──────────────────────────────────────

# Daily report time (24-hour format)
REPORT_HOUR=21
REPORT_MINUTE=0

# Timezone (IANA format)
TIMEZONE=Asia/Kolkata

# Default currency symbol
CURRENCY_SYMBOL=₹

# OpenAI model to use
OPENAI_MODEL=gpt-4o
